# 1. نحدد البيئة الأساسية (نسخة Node.js)
FROM node:18

# 2. ننشئ مجلد داخل الكبسولة ليوضع فيه الكود
WORKDIR /app

# 3. ننسخ ملفات الحزم أولاً لتثبيتها
COPY package*.json ./
RUN npm install

# 4. ننسخ باقي ملفات المشروع بالكامل إلى داخل الكبسولة
COPY . .

# 5. نحدد البورت الذي يشتغل عليه مشروعك (مثلاً 5000)
EXPOSE 5000

# 6. الأمر النهائي الذي يشغل المشروع
CMD ["node", "server.js"]